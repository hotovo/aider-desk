{
  "name": "@aiderdesk/mcp-server",
  "version": "0.2.0",
  "description": "MCP server that exposes AiderDesk functionality to external MCP-compatible clients",
  "author": "Hotovo",
  "homepage": "https://aiderdesk.hotovo.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/hotovo/aider-desk.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/hotovo/aider-desk/issues"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "bin": {
