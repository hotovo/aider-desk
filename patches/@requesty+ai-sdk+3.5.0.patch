--- a/node_modules/@requesty/ai-sdk/dist/index.js
+++ b/node_modules/@requesty/ai-sdk/dist/index.js
@@ -154,7 +154,16 @@ const DEFAULT_PDF_NAME = "unnamed.pdf";
 function toBase64DataUrl(base64Data, mediaType) {
 	return `data:${mediaType};base64,${base64Data}`;
 }
+function unwrapFileData(data) {
+	if (data && typeof data === "object" && !Array.isArray(data) && !(data instanceof Uint8Array) && !(data instanceof URL)) {
+		if (data.type === "data") return data.data;
+		if (data.type === "url") return new URL(data.url);
+		if (data.type === "text") return data.text;
+	}
+	return data;
+}
 function transformUrl({ data, mediaType }) {
+	data = unwrapFileData(data);
 	if (data instanceof Uint8Array) return [toBase64DataUrl(Buffer.from(data).toString("base64"), mediaType), true];
 	if (data instanceof URL) return [data.href, false];
 	if (typeof data === "string") if (data.startsWith("data:")) return [data, true];
